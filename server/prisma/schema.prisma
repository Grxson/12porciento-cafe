generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  category    String      @default("CAFÉ")
  origin      String?
  region      String?
  altitude    Int?
  variety     String?
  process     String?
  scaScore    Float?
  roastLevel  String?
  flavors     String?
  images      String?
  recipes     String?
  price       Float
  weight      Int?
  stock       Int
  lowStockThreshold Int    @default(10)
  sku           String?  @unique
  costPrice     Float?
  supplier      String?
  minOrderQty   Int?     @default(1)
  imageUrl    String
  description String
  isLimited   Boolean     @default(false)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems        OrderItem[]
  bundleItems       BundleItem[]
  reviews           Review[]
  subscriptionItems SubscriptionItem[]
  stockMovements    StockMovement[]
  linkedRecipes Recipe[] @relation("productRecipes")
}

model StockMovement {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type          String   // SALE | RESTOCK | ADJUSTMENT | LOSS | RETURN | INITIAL
  quantity      Int      // positive = in, negative = out
  previousStock Int
  newStock      Int
  notes         String?
  orderId       String?
  unitCost    Float?
  batchNumber String?
  expiryDate  DateTime?
  supplier    String?
  createdAt     DateTime @default(now())

  @@index([productId])
  @@index([type])
  @@index([createdAt])
}

model Order {
  id           String      @id @default(cuid())
  customerName String
  email        String
  phone        String?
  address      String
  city         String
  state        String
  zipCode      String
  total            Float
  status           String      @default("PENDING")
  notes            String?
  userId           String?
  paymentIntentId  String?     @unique
  user             User?       @relation(fields: [userId], references: [id])
  items            OrderItem[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Subscription {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  phone             String?
  plan              String
  grindPreference   String             @default("GRANO")
  fulfillmentStatus String             @default("PENDIENTE")
  userId            String?
  user              User?              @relation(fields: [userId], references: [id])
  frequency         String             @default("monthly")
  status            String             @default("ACTIVE")
  nextBilling       DateTime
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  items             SubscriptionItem[]

  stripeSubscriptionId  String? @unique
  stripeCustomerId      String?
  stripePaymentMethodId String?

  lastPaymentId     String?
  lastPaymentDate   DateTime?
  failedAttempts    Int     @default(0)
  lastFailureReason String?

  payments SubscriptionPayment[]
}

model SubscriptionPayment {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  stripeInvoiceId String? @unique
  stripeChargeId  String? @unique

  amount      Float
  status      String   @default("PENDING")
  billingDate DateTime

  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subscriptionId])
  @@index([billingDate])
}

model SubscriptionItem {
  id             String       @id @default(cuid())
  subscriptionId String
  productId      String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  product        Product      @relation(fields: [productId], references: [id])
}

model Bundle {
  id            String         @id @default(cuid())
  name          String
  description   String
  basePrice     Float
  discountPct   Int            @default(0)
  finalPrice    Float
  imageUrl      String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  items         BundleItem[]
}

model BundleItem {
  id        String  @id @default(cuid())
  bundleId  String
  productId String
  quantity  Int     @default(1)
  bundle    Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String
  email      String
  rating     Int
  comment    String
  isApproved    Boolean   @default(false)
  adminResponse String?
  respondedAt   DateTime?
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  replies       ReviewReply[] @relation("replies")
  createdAt     DateTime  @default(now())
}

model Recipe {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  method      String
  difficulty  String   @default("MEDIA")
  prepTime    Int?
  yield       String?
  temp        String?
  grind       String?
  ratio       String?
  isPremium   Boolean  @default(false)
  isPublished Boolean  @default(false)

  productId   String?
  product     Product? @relation("productRecipes", fields: [productId], references: [id], onDelete: SetNull)

  steps       RecipeStep[]
  brewLogs    BrewLog[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([method])
  @@index([isPremium])
}

model RecipeStep {
  id          String  @id @default(cuid())
  recipeId    String
  recipe      Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  order       Int
  title       String
  description String
  imageUrl    String?
  videoUrl    String?
  duration    Int?

  @@index([recipeId])
  @@unique([recipeId, order])
}

model ReviewReply {
  id       String @id @default(cuid())
  reviewId String
  review   Review @relation("replies", fields: [reviewId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation("reviewReplies", fields: [userId], references: [id], onDelete: SetNull)

  name       String
  content    String
  isApproved Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reviewId])
  @@index([userId])
}

model PromoCode {
  id          String    @id @default(cuid())
  code        String    @unique
  discount    Float
  type        String    @default("PERCENT")
  maxUses     Int?
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
}

model AdminUser {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model User {
  id                           String         @id @default(cuid())
  name                         String
  email                        String         @unique
  password                     String
  phone                        String?
  address                      String?
  city                         String?
  state                        String?
  zipCode                      String?
  avatarUrl                    String?
  resetToken                   String?
  resetTokenExpires            DateTime?
  stripeCustomerId             String?        @unique
  stripeDefaultPaymentMethodId String?
  createdAt                    DateTime       @default(now())
  updatedAt                    DateTime       @updatedAt
  orders                       Order[]
  reviews                      Review[]
  subscriptions                Subscription[]
  reviewReplies                ReviewReply[] @relation("reviewReplies")
  baristaProfile               BaristaProfile?
}

model BaristaProfile {
  id             String              @id @default(cuid())
  userId         String              @unique
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  level          Int                 @default(1)
  totalXp        Int                 @default(0)
  totalBrews     Int                 @default(0)
  favoriteMethod String?
  brewLogs       BrewLog[]
  achievements   AchievementUnlock[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([userId])
}

model BrewLog {
  id             String         @id @default(cuid())
  clientBrewId   String?        @unique
  userId         String
  baristaProfile BaristaProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  recipeId       String
  recipe         Recipe         @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  rating         Int            @default(3)
  notes          String?
  photoUrl       String?
  xpEarned       Int            @default(0)
  createdAt      DateTime       @default(now())

  @@index([userId])
  @@index([recipeId])
  @@index([clientBrewId])
}

model Achievement {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  description String
  icon        String
  rarity      String              @default("COMMON")
  xpReward    Int                 @default(10)
  unlocks     AchievementUnlock[]

  @@index([slug])
}

model AchievementUnlock {
  id             String         @id @default(cuid())
  userId         String
  baristaProfile BaristaProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  achievementId  String
  achievement    Achievement    @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt     DateTime       @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

model B2BInquiry {
  id String @id @default(cuid())
  empresa String
  rfc String
  contactoNombre String
  contactoEmail String
  contactoTelefono String
  volumenEstimado String
  giroNegocio String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactoEmail])
}
